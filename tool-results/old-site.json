    "html": "<html lang=\"en\"><head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Ashioya Jotham Victor | ML Researcher</title>\n    <meta name=\"description\" content=\"Machine Learning Researcher focused on AI safety, reasoning mechanisms, and interpretability. Google Developer Expert (GDE) - AI. Exploring technical AI safety at Bluedot.\">\n    <meta name=\"keywords\" content=\"AI Safety, Machine Learning, Interpretability, AI Alignment, Google Developer Expert, GDE, Bluedot, GDG Pwani\">\n    <meta name=\"author\" content=\"Ashioya Jotham Victor\">\n    <link rel=\"canonical\" href=\"https://ashioyajotham.github.io/\">\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"elephant.ico\">\n    <link rel=\"alternate\" type=\"application/rss+xml\" title=\"Essays by Ashioya Jotham Victor\" href=\"https://ashioyajotham.github.io/feed.xml\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css\">\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"\">\n    <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&amp;display=swap\" rel=\"stylesheet\">\n    <script src=\"main.js\"></script>\n\n    <!-- JSON-LD Structured Data -->\n    <script type=\"application/ld+json\">\n    {\n        \"@context\": \"https://schema.org\",\n        \"@type\": \"Person\",\n        \"name\": \"Ashioya Jotham Victor\",\n        \"givenName\": \"Jotham\",\n        \"familyName\": \"Ashioya\",\n        \"additionalName\": \"Victor\",\n        \"url\": \"https://ashioyajotham.github.io\",\n        \"image\": \"https://ashioyajotham.github.io/profile.jpg\",\n        \"description\": \"Machine Learning Researcher focused on AI safety, reasoning mechanisms, and mitigating hallucinations in language models.\",\n        \"jobTitle\": [\"Machine Learning Researcher\", \"Google Developer Expert - AI\", \"Partnerships Lead\"],\n        \"worksFor\": [\n            {\n                \"@type\": \"Organization\",\n                \"name\": \"Bluedot\",\n                \"url\": \"https://www.bluedot.org/\",\n                \"description\": \"Technical AI Safety\"\n            },\n            {\n                \"@type\": \"Organization\",\n                \"name\": \"Google Developer Group (GDG) Pwani\",\n                \"url\": \"https://gdg.community.dev/gdg-pwani/\"\n            }\n        ],\n        \"alumniOf\": {\n            \"@type\": \"EducationalOrganization\",\n            \"name\": \"Kabarak University\",\n            \"url\": \"https://www.kabarak.ac.ke/\"\n        },\n        \"knowsAbout\": [\n            \"Artificial Intelligence\",\n            \"Machine Learning\",\n            \"AI Safety\",\n            \"AI Alignment\",\n            \"Interpretability\",\n            \"Neural Networks\",\n            \"Large Language Models\",\n            \"Mechanistic Interpretability\"\n        ],\n        \"sameAs\": [\n            \"https://github.com/ashioyajotham\",\n            \"https://twitter.com/ashioyajotham_\",\n            \"https://www.linkedin.com/in/ashioyajotham/\",\n            \"https://ashioyajotham.substack.com\",\n            \"https://www.lesswrong.com/users/victor-ashioya\"\n        ],\n        \"memberOf\": {\n            \"@type\": \"ProgramMembership\",\n            \"programName\": \"Google Developer Experts\",\n            \"hostingOrganization\": {\n                \"@type\": \"Organization\",\n                \"name\": \"Google\",\n                \"url\": \"https://developers.google.com/community/experts\"\n            },\n            \"member\": {\n                \"@type\": \"Person\",\n                \"name\": \"Ashioya Jotham Victor\"\n            },\n            \"description\": \"A global network of experienced technology experts, influencers, and thought leaders recognized for their expertise in Google technologies\"\n        }\n    }\n    </script>\n\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n            line-height: 1.7;\n            color: #1a1a1a;\n            background: #fafafa;\n            padding: 2rem 1.5rem;\n            max-width: 720px;\n            margin: 0 auto;\n            transition: background-color 0.3s, color 0.3s;\n        }\n\n        /* Dark mode */\n        body.dark-mode {\n            background: #1a1a2e;\n            color: #e0e0e0;\n        }\n\n        nav {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 4rem;\n        }\n\n        .nav-links {\n            display: flex;\n            align-items: center;\n            gap: 1.5rem;\n        }\n\n        .nav-links a {\n            color: #666;\n            text-decoration: none;\n            font-size: 0.95rem;\n            transition: color 0.2s;\n        }\n\n        .nav-links a:hover {\n            color: #1a1a1a;\n        }\n\n        body.dark-mode .nav-links a {\n            color: #aaa;\n        }\n\n        body.dark-mode .nav-links a:hover {\n            color: #fff;\n        }\n\n        .theme-toggle {\n            background: none;\n            border: none;\n            cursor: pointer;\n            font-size: 1rem;\n            color: #666;\n            padding: 0.25rem;\n        }\n\n        body.dark-mode .theme-toggle {\n            color: #aaa;\n        }\n\n        /* Profile photo */\n        .profile-img {\n            width: 80px;\n            height: 80px;\n            border-radius: 50%;\n            object-fit: cover;\n            margin-bottom: 1.5rem;\n        }\n\n        /* Name */\n        .name {\n            font-size: 1.1rem;\n            font-weight: 500;\n            color: #666;\n            margin-bottom: 0.5rem;\n            letter-spacing: 0.02em;\n        }\n\n        body.dark-mode .name {\n            color: #aaa;\n        }\n\n        /* Hero statement */\n        .hero-statement {\n            font-size: 2rem;\n            font-weight: 600;\n            line-height: 1.3;\n            margin-bottom: 1.5rem;\n            color: #111;\n        }\n\n        body.dark-mode .hero-statement {\n            color: #f0f0f0;\n        }\n\n        /* Bio */\n        .bio {\n            margin-bottom: 1.5rem;\n        }\n\n        .bio p {\n            margin-bottom: 1rem;\n            color: #444;\n        }\n\n        body.dark-mode .bio p {\n            color: #bbb;\n        }\n\n        .bio a {\n            color: #0066cc;\n            text-decoration: none;\n        }\n\n        .bio a:hover {\n            text-decoration: underline;\n        }\n\n        body.dark-mode .bio a {\n            color: #6db3f2;\n        }\n\n        /* Social row */\n        .social-row {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            margin-bottom: 3rem;\n            font-size: 0.95rem;\n            color: #666;\n        }\n\n        .social-row .sep {\n            color: #ccc;\n        }\n\n        .social-row a {\n            color: #0066cc;\n            text-decoration: none;\n        }\n\n        .social-row a:hover {\n            text-decoration: underline;\n        }\n\n        body.dark-mode .social-row {\n            color: #aaa;\n        }\n\n        body.dark-mode .social-row .sep {\n            color: #555;\n        }\n\n        body.dark-mode .social-row a {\n            color: #6db3f2;\n        }\n\n        /* Sections */\n        .section {\n            margin-bottom: 3rem;\n        }\n\n        .section-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 1rem;\n            padding-bottom: 0.5rem;\n            border-bottom: 1px solid #e0e0e0;\n        }\n\n        body.dark-mode .section-header {\n            border-bottom-color: #444;\n        }\n\n        .section-title {\n            font-size: 0.85rem;\n            font-weight: 600;\n            color: #888;\n            text-transform: uppercase;\n            letter-spacing: 0.05em;\n        }\n\n        .section-link {\n            font-size: 0.9rem;\n            color: #666;\n            text-decoration: none;\n        }\n\n        .section-link:hover {\n            color: #1a1a1a;\n        }\n\n        body.dark-mode .section-link {\n            color: #aaa;\n        }\n\n        body.dark-mode .section-link:hover {\n            color: #fff;\n        }\n\n        /* Essay card */\n        .essay-card {\n            padding: 1.5rem 0;\n        }\n\n        .essay-card a {\n            text-decoration: none;\n            color: inherit;\n        }\n\n        .essay-title {\n            font-size: 1.25rem;\n            font-weight: 600;\n            margin-bottom: 0.25rem;\n            color: #1a1a1a;\n        }\n\n        body.dark-mode .essay-title {\n            color: #f0f0f0;\n        }\n\n        .essay-card a:hover .essay-title {\n            color: #0066cc;\n        }\n\n        body.dark-mode .essay-card a:hover .essay-title {\n            color: #6db3f2;\n        }\n\n        .essay-date {\n            font-size: 0.9rem;\n            color: #888;\n            margin-bottom: 0.5rem;\n        }\n\n        .essay-desc {\n            color: #555;\n            line-height: 1.6;\n        }\n\n        body.dark-mode .essay-desc {\n            color: #bbb;\n        }\n\n        /* Project item */\n        .project-item {\n            padding: 1rem 0;\n            border-bottom: 1px solid #eee;\n        }\n\n        .project-item:last-child {\n            border-bottom: none;\n        }\n\n        body.dark-mode .project-item {\n            border-bottom-color: #333;\n        }\n\n        .project-item a {\n            text-decoration: none;\n            color: inherit;\n        }\n\n        .project-name {\n            font-size: 1.1rem;\n            font-weight: 600;\n            color: #1a1a1a;\n            margin-bottom: 0.25rem;\n        }\n\n        body.dark-mode .project-name {\n            color: #f0f0f0;\n        }\n\n        .project-item a:hover .project-name {\n            color: #0066cc;\n        }\n\n        body.dark-mode .project-item a:hover .project-name {\n            color: #6db3f2;\n        }\n\n        .project-desc {\n            font-size: 0.95rem;\n            color: #666;\n        }\n\n        body.dark-mode .project-desc {\n            color: #aaa;\n        }\n\n        /* Footer */\n        footer {\n            margin-top: 4rem;\n            padding-top: 1.5rem;\n            border-top: 1px solid #e0e0e0;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            font-size: 0.9rem;\n            color: #888;\n        }\n\n        body.dark-mode footer {\n            border-top-color: #444;\n        }\n\n        .footer-links {\n            display: flex;\n            gap: 1.25rem;\n        }\n\n        .footer-links a {\n            color: #666;\n            text-decoration: none;\n        }\n\n        .footer-links a:hover {\n            color: #1a1a1a;\n        }\n\n        body.dark-mode .footer-links a {\n            color: #aaa;\n        }\n\n        body.dark-mode .footer-links a:hover {\n            color: #fff;\n        }\n    </style>\n</head>\n\n<body>\n    <nav>\n        <div class=\"nav-links\">\n            <a href=\"research.html\">Research</a>\n            <a href=\"projects.html\">Projects</a>\n            <a href=\"essays.html\">Essays</a>\n            <a href=\"now.html\">Now</a>\n            <button class=\"theme-toggle\" onclick=\"toggleDarkMode()\">\n                <i class=\"fas fa-moon\"></i>\n            </button>\n        </div>\n    </nav>\n\n    <main>\n        <img src=\"profile.jpg\" alt=\"Victor Jotham Ashioya\" class=\"profile-img\">\n\n        <h2 class=\"name\">Victor Jotham Ashioya</h2>\n        <h1 class=\"hero-statement\">I study how neural networks encode knowledge and make decisions.</h1>\n\n        <div class=\"bio\">\n            <p>I'm an ML researcher focused on AI safety, reasoning mechanisms, and mitigating hallucinations in\n                language models. Currently exploring technical AI safety at <a href=\"https://www.bluedot.org/\" target=\"_blank\" rel=\"noopener\">Bluedot</a>.</p>\n            <p>I also lead partnerships at <a href=\"https://gdg.community.dev/gdg-pwani/\" target=\"_blank\" rel=\"noopener\">GDG Pwani</a> and am a Google Developer Expert in AI.</p>\n        </div>\n\n        <div class=\"social-row\">\n            <a href=\"mailto:victorashioya960@gmail.com\">Email</a>\n            <span class=\"sep\">·</span>\n            <a href=\"https://twitter.com/ashioyajotham_\" target=\"_blank\">X</a>\n            <span class=\"sep\">·</span>\n            <a href=\"https://github.com/ashioyajotham\" target=\"_blank\">GitHub</a>\n            <span class=\"sep\">·</span>\n            <a href=\"https://www.linkedin.com/in/ashioyajotham/\" target=\"_blank\">LinkedIn</a>\n        </div>\n\n        <section class=\"section\">\n            <div class=\"section-header\">\n                <span class=\"section-title\">Latest Essay</span>\n                <a href=\"essays.html\" class=\"section-link\">All essays →</a>\n            </div>\n            <div class=\"essay-card\">\n                <a href=\"essays/ai-priesthood.html\">\n                    <div class=\"essay-title\">AI Priesthood vs AI Pluralism</div>\n                    <div class=\"essay-date\">February 4, 2026</div>\n                    <p class=\"essay-desc\">On builders, clerics, and the future of intelligence. Every major\n                        technological revolution produces two kinds of institutions — and AI is no different.</p>\n                </a>\n            </div>\n        </section>\n\n        <section class=\"section\">\n            <div class=\"section-header\">\n                <span class=\"section-title\">Selected Work</span>\n                <a href=\"projects.html\" class=\"section-link\">All projects →</a>\n            </div>\n            <div class=\"project-item\">\n                <a href=\"ai-compute-simulator/index.html\" target=\"_blank\">\n                    <div class=\"project-name\">AI Compute Growth Simulator</div>\n                    <p class=\"project-desc\">Interactive tool for modeling AI compute trajectories</p>\n                </a>\n            </div>\n            <div class=\"project-item\">\n                <a href=\"https://github.com/ashioyajotham/exploring_saes\" target=\"_blank\">\n                    <div class=\"project-name\">Interpretability Tools</div>\n                    <p class=\"project-desc\">Open-source resources for understanding model internals</p>\n                </a>\n            </div>\n        </section>\n    </main>\n\n    <footer>\n        <span>© <span id=\"currentYear\">2026</span> Ashioya Jotham Victor</span>\n        <div class=\"footer-links\">\n            <a href=\"feed.xml\">RSS</a>\n            <a href=\"https://ashioyajotham.substack.com\" target=\"_blank\">Substack</a>\n        </div>\n    </footer>\n\n    <script>\n        document.getElementById('currentYear').textContent = new Date().getFullYear();\n    </script>\n\n\n</body></html>",
