    "html": "<html lang=\"en\"><head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Research | Ashioya Jotham Victor</title>\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"elephant.ico\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css\">\n    <script src=\"main.js\"></script>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Georgia', serif;\n            line-height: 1.75;\n            color: #1a1a1a;\n            background: #fafafa;\n        }\n\n        .container {\n            max-width: 1100px;\n            margin: 0 auto;\n            padding: 2rem 1.5rem;\n        }\n\n        nav {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            margin-bottom: 3rem;\n        }\n\n        nav a {\n            color: #666;\n            text-decoration: none;\n            margin-right: 1.5rem;\n            font-size: 0.9rem;\n        }\n\n        nav a:hover {\n            color: #1a1a1a;\n        }\n\n        /* Hero */\n        .hero {\n            display: grid;\n            grid-template-columns: 1fr 300px;\n            gap: 3rem;\n            margin-bottom: 4rem;\n            padding-bottom: 3rem;\n            border-bottom: 1px solid #e0e0e0;\n        }\n\n        @media (max-width: 800px) {\n            .hero {\n                grid-template-columns: 1fr;\n            }\n        }\n\n        .hero-main h1 {\n            font-size: 2.25rem;\n            font-weight: 400;\n            line-height: 1.3;\n            margin-bottom: 1.5rem;\n            letter-spacing: -0.02em;\n        }\n\n        .hero-main p {\n            font-size: 1.1rem;\n            color: #444;\n            margin-bottom: 1rem;\n        }\n\n        .hero-main a {\n            color: #1a1a1a;\n            text-decoration: underline;\n            text-decoration-color: #ccc;\n            text-underline-offset: 3px;\n        }\n\n        .hero-main a:hover {\n            text-decoration-color: #1a1a1a;\n        }\n\n        /* Beliefs panel */\n        .beliefs-panel {\n            background: #1a1a1a;\n            color: #fff;\n            padding: 1.5rem;\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            height: fit-content;\n        }\n\n        .beliefs-panel h2 {\n            font-size: 0.75rem;\n            font-weight: 600;\n            text-transform: uppercase;\n            letter-spacing: 0.1em;\n            color: #888;\n            margin-bottom: 1rem;\n        }\n\n        .beliefs-panel ul {\n            list-style: none;\n            font-size: 0.9rem;\n            line-height: 1.6;\n        }\n\n        .beliefs-panel li {\n            margin-bottom: 0.75rem;\n            padding-left: 0.75rem;\n            border-left: 2px solid #444;\n        }\n\n        .beliefs-panel a {\n            display: inline-block;\n            margin-top: 1rem;\n            font-size: 0.8rem;\n            color: #888;\n            text-decoration: none;\n        }\n\n        .beliefs-panel a:hover {\n            color: #fff;\n        }\n\n        /* Main content */\n        .main-content {\n            display: grid;\n            grid-template-columns: 1fr 300px;\n            gap: 3rem;\n        }\n\n        @media (max-width: 800px) {\n            .main-content {\n                grid-template-columns: 1fr;\n            }\n\n            .sidebar {\n                order: -1;\n            }\n        }\n\n        /* Sections */\n        .section {\n            margin-bottom: 3.5rem;\n        }\n\n        h2.section-title {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 0.75rem;\n            font-weight: 600;\n            text-transform: uppercase;\n            letter-spacing: 0.1em;\n            color: #888;\n            margin-bottom: 1.5rem;\n            padding-bottom: 0.5rem;\n            border-bottom: 1px solid #e0e0e0;\n        }\n\n        /* The Arc - narrative timeline */\n        .arc-narrative {\n            font-size: 1.05rem;\n        }\n\n        .arc-narrative p {\n            margin-bottom: 1.25rem;\n        }\n\n        .arc-year {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 0.8rem;\n            font-weight: 600;\n            color: #888;\n            display: inline-block;\n            margin-right: 0.5rem;\n        }\n\n        .arc-narrative a {\n            color: #1a1a1a;\n            text-decoration: underline;\n            text-decoration-color: #ccc;\n        }\n\n        /* Quote banner */\n        .quote-banner {\n            background: #1a1a1a;\n            color: #fff;\n            padding: 2.5rem 3rem;\n            margin-bottom: 3rem;\n            font-family: Georgia, serif;\n        }\n\n        .quote-banner blockquote {\n            font-size: 1.35rem;\n            font-style: italic;\n            line-height: 1.5;\n            margin: 0;\n            color: #e0e0e0;\n        }\n\n        .quote-banner .quote-source {\n            margin-top: 1.25rem;\n            font-size: 0.9rem;\n            font-style: normal;\n            color: #888;\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n        }\n\n        .quote-banner .quote-source a {\n            color: #888;\n            text-decoration: underline;\n            text-decoration-color: #555;\n        }\n\n        .quote-banner .quote-source a:hover {\n            color: #fff;\n        }\n\n        /* Projects */\n        .project-item {\n            margin-bottom: 1.75rem;\n            padding-bottom: 1.5rem;\n            border-bottom: 1px solid #eee;\n        }\n\n        .project-item:last-child {\n            border-bottom: none;\n        }\n\n        .project-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: baseline;\n            margin-bottom: 0.5rem;\n            flex-wrap: wrap;\n            gap: 0.5rem;\n        }\n\n        .project-title {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 1rem;\n            font-weight: 600;\n        }\n\n        .project-title a {\n            color: inherit;\n            text-decoration: none;\n        }\n\n        .project-title a:hover {\n            color: #0066cc;\n        }\n\n        .project-status {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 0.7rem;\n            text-transform: uppercase;\n            letter-spacing: 0.05em;\n            padding: 0.2rem 0.5rem;\n            border-radius: 2px;\n        }\n\n        .status-active {\n            background: #e8f5e9;\n            color: #2e7d32;\n        }\n\n        .status-writing {\n            background: #fff3e0;\n            color: #e65100;\n        }\n\n        .project-featured {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 0.85rem;\n            color: #b8860b;\n            margin-bottom: 0.5rem;\n        }\n\n        .project-featured a {\n            color: #b8860b;\n            text-decoration: underline;\n            text-decoration-color: rgba(184, 134, 11, 0.4);\n        }\n\n        .project-featured a:hover {\n            color: #8b6914;\n            text-decoration-color: #8b6914;\n        }\n\n        .project-desc {\n            font-size: 0.95rem;\n            color: #555;\n            margin-bottom: 0.5rem;\n        }\n\n        .project-question {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 0.85rem;\n            color: #888;\n        }\n\n        .project-question strong {\n            color: #666;\n        }\n\n        /* Sidebar */\n        .sidebar {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n        }\n\n        .sidebar-section {\n            margin-bottom: 2.5rem;\n        }\n\n        .sidebar-section h3 {\n            font-size: 0.75rem;\n            font-weight: 600;\n            text-transform: uppercase;\n            letter-spacing: 0.1em;\n            color: #888;\n            margin-bottom: 1rem;\n        }\n\n        /* Publications in sidebar */\n        .pub-item {\n            margin-bottom: 1.25rem;\n        }\n\n        .pub-year {\n            font-size: 0.75rem;\n            color: #999;\n        }\n\n        .pub-title {\n            font-size: 0.9rem;\n            font-weight: 500;\n            margin-bottom: 0.15rem;\n        }\n\n        .pub-title a {\n            color: inherit;\n            text-decoration: none;\n        }\n\n        .pub-title a:hover {\n            color: #0066cc;\n        }\n\n        .pub-venue {\n            font-size: 0.8rem;\n            color: #666;\n        }\n\n        /* Research diary callout */\n        .diary-box {\n            background: #fff;\n            border: 1px solid #e0e0e0;\n            padding: 1.25rem;\n        }\n\n        .diary-box h3 {\n            font-size: 0.9rem;\n            font-weight: 600;\n            margin-bottom: 0.5rem;\n        }\n\n        .diary-box p {\n            font-size: 0.85rem;\n            color: #666;\n            margin-bottom: 0.75rem;\n        }\n\n        .diary-box a {\n            font-size: 0.8rem;\n            color: #1a1a1a;\n            text-decoration: none;\n        }\n\n        .diary-box a:hover {\n            text-decoration: underline;\n        }\n\n        footer {\n            margin-top: 4rem;\n            padding-top: 1.5rem;\n            border-top: 1px solid #e0e0e0;\n            font-size: 0.85rem;\n            color: #888;\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n        }\n\n        /* Theme toggle */\n        .theme-toggle {\n            background: none;\n            border: none;\n            cursor: pointer;\n            font-size: 1rem;\n            color: #666;\n            padding: 0.25rem;\n            vertical-align: middle;\n        }\n\n        /* Dark mode */\n        body.dark-mode {\n            background: #1a1a2e;\n            color: #e0e0e0;\n        }\n\n        body.dark-mode .container {\n            background: #1a1a2e;\n        }\n\n        body.dark-mode nav a {\n            color: #aaa;\n        }\n\n        body.dark-mode nav a:hover {\n            color: #fff;\n        }\n\n        body.dark-mode .theme-toggle {\n            color: #aaa;\n        }\n\n        body.dark-mode .hero-main h1 {\n            color: #f0f0f0;\n        }\n\n        body.dark-mode .hero-main p {\n            color: #bbb;\n        }\n\n        body.dark-mode .hero-main a {\n            color: #6db3f2;\n            text-decoration-color: #555;\n        }\n\n        body.dark-mode .beliefs-panel {\n            background: #0d0d1a;\n        }\n\n        body.dark-mode .section-title {\n            color: #888;\n            border-bottom-color: #444;\n        }\n\n        body.dark-mode .arc-narrative {\n            color: #ccc;\n        }\n\n        body.dark-mode .arc-narrative a {\n            color: #6db3f2;\n        }\n\n        body.dark-mode .quote-banner {\n            background: #0d0d1a;\n        }\n\n        body.dark-mode .quote-banner blockquote {\n            color: #ccc;\n        }\n\n        body.dark-mode .project-title a {\n            color: #f0f0f0;\n        }\n\n        body.dark-mode .project-title a:hover {\n            color: #6db3f2;\n        }\n\n        body.dark-mode .project-desc {\n            color: #aaa;\n        }\n\n        body.dark-mode .project-item {\n            border-bottom-color: #333;\n        }\n\n        body.dark-mode .project-featured {\n            color: #daa520;\n        }\n\n        body.dark-mode .project-featured a {\n            color: #daa520;\n            text-decoration-color: rgba(218, 165, 32, 0.4);\n        }\n\n        body.dark-mode .project-featured a:hover {\n            color: #ffd700;\n            text-decoration-color: #ffd700;\n        }\n\n        body.dark-mode .pub-title a {\n            color: #f0f0f0;\n        }\n\n        body.dark-mode .pub-title a:hover {\n            color: #6db3f2;\n        }\n\n        body.dark-mode .pub-venue {\n            color: #888;\n        }\n\n        body.dark-mode .diary-box {\n            background: #252540;\n            border-color: #444;\n        }\n\n        body.dark-mode .diary-box p {\n            color: #aaa;\n        }\n\n        body.dark-mode .diary-box a {\n            color: #6db3f2;\n        }\n\n        body.dark-mode footer {\n            border-top-color: #444;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"container\">\n        <nav>\n            <a href=\"index.html\">Home</a>\n            <a href=\"research.html\">Research</a>\n            <a href=\"projects.html\">Projects</a>\n            <a href=\"essays.html\">Essays</a>\n            <a href=\"now.html\">Now</a>\n            <button class=\"theme-toggle\" onclick=\"toggleDarkMode()\">\n                <i class=\"fas fa-moon\"></i>\n            </button>\n        </nav>\n\n        <div class=\"hero\">\n            <div class=\"hero-main\">\n                <h1>I don't think scaling gets us to robust reasoning.</h1>\n                <p>Language models exhibit what Ethan Mollick calls <a href=\"https://papers.ssrn.com/sol3/papers.cfm?abstract_id=4573321\">\"jagged intelligence\"</a>:\n                    superhuman at some tasks, brittle at others humans find trivial. This jagged profile is why\n                    interpretability matters—we need to understand <em>where</em> and <em>why</em> systems break.</p>\n                <p>My work traces how specific neurons, attention heads, and pathways give rise to model capabilities\n                    and failures. I'm particularly drawn to <strong>hallucinations</strong>: when models produce\n                    confident-but-wrong outputs.</p>\n            </div>\n            <div class=\"beliefs-panel\">\n                <h2>Where I Stand</h2>\n                <ul>\n                    <li>World models &gt; scaling language models</li>\n                    <li>Alignment is stewardship, not prophecy</li>\n                    <li>Pessimism ≠ intelligence</li>\n                    <li>To see a failure mode is to inherit responsibility for it</li>\n                </ul>\n                <a href=\"https://open.substack.com/pub/ashioyajotham/p/my-research-ethos-for-alignment-and\">Full ethos\n                    →</a>\n            </div>\n        </div>\n\n        <div class=\"quote-banner\">\n            <blockquote>\n                \"We offer no explanation as to why these architectures seem to work; we attribute their success, as all\n                else, to divine benevolence.\"\n            </blockquote>\n            <div class=\"quote-source\">\n                — Noam Shazeer, <a href=\"https://arxiv.org/abs/2002.05202\">GLU Variants Improve Transformer</a> (2020)\n            </div>\n        </div>\n\n        <div class=\"main-content\">\n            <div class=\"content\">\n                <div class=\"section\">\n                    <h2 class=\"section-title\">How I Got Here</h2>\n                    <div class=\"arc-narrative\">\n                        <p><span class=\"arc-year\">2023</span> I started with the intuition that self-supervised\n                            approaches were undersold. The field was drunk on supervised fine-tuning; I wrote <a href=\"https://openreview.net/forum?id=Hk7QOUpP82\">\"The Future Remains Unsupervised\"</a>\n                            for Deep Learning Indaba as a counterweight.</p>\n\n                        <p><span class=\"arc-year\">2024</span> Then I got interested in failure modes. Why do models\n                            produce confident nonsense? The term \"hallucination\" felt too forgiving—I started calling it\n                            <em>confabulation</em>, borrowing from neuroscience. Began building <a href=\"https://github.com/ashioyajotham/Value-Aligned-Confabulation-VAC-Research\">metrics\n                                for measuring it</a>.\n                        </p>\n\n                        <p><span class=\"arc-year\">2025</span> Now I'm going deeper: mechanistic interpretability. Can we\n                            detect when a model \"knows\" it's being evaluated? Can we find the exact pathways where\n                            reasoning goes wrong? The work is harder but more satisfying. I'm at <a href=\"https://www.bluedot.org/\">Bluedot</a> this year, focused on this full-time.</p>\n                    </div>\n                </div>\n\n                <div class=\"section\">\n                    <h2 class=\"section-title\">Active Projects</h2>\n\n                    <div class=\"project-item\">\n                        <div class=\"project-header\">\n                            <span class=\"project-title\"><a href=\"https://github.com/ashioyajotham/cot-faithfulness-mech-interp\">Chain-of-Thought\n                                    Faithfulness</a></span>\n                            <span class=\"project-status status-active\">Active</span>\n                        </div>\n                        <p class=\"project-featured\">🏆 <a href=\"https://blog.bluedot.org/p/mechanistic-analysis-of-chain-of\">Top 5 at Bluedot Demo\n                                Day</a></p>\n                        <p class=\"project-desc\">Mechanistic analysis of reasoning faithfulness in GPT-2 Small. Linear\n                            probe achieves 88% accuracy (ROC-AUC 0.949) detecting unfaithful CoT from residual streams.\n                            Identified 23 causal circuit components; steering vectors achieve ~72% success shifting\n                            unfaithful → faithful.</p>\n                        <p class=\"project-question\"><strong>Open:</strong> Do these circuits generalize across model\n                            scales and reasoning tasks?</p>\n                    </div>\n\n                    <div class=\"project-item\">\n                        <div class=\"project-header\">\n                            <span class=\"project-title\"><a href=\"https://github.com/ashioyajotham/eval-awareness-research\">Evaluation Awareness\n                                    Detection</a></span>\n                            <span class=\"project-status status-active\">Active</span>\n                        </div>\n                        <p class=\"project-desc\">Do LLMs internally represent being monitored? Found 92.3% probe accuracy\n                            at layer 16 with 70.3% transfer to subtle cues.</p>\n                        <p class=\"project-question\"><strong>Open:</strong> Does awareness direction causally affect\n                            policy decisions?</p>\n                    </div>\n\n                    <div class=\"project-item\">\n                        <div class=\"project-header\">\n                            <span class=\"project-title\"><a href=\"https://github.com/ashioyajotham/weather_forecasting_lora\">Weather Forecasting\n                                    with LoRA</a></span>\n                            <span class=\"project-status status-writing\">Writing up</span>\n                        </div>\n                        <p class=\"project-desc\">Testing \"LoRA Without Regret\" methodology on numerical → natural\n                            language forecasts.</p>\n                        <p class=\"project-question\"><strong>Open:</strong> Can RLHF optimize for both accuracy and\n                            style?</p>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"sidebar\">\n                <div class=\"sidebar-section\">\n                    <h3>Selected Publications</h3>\n\n                    <div class=\"pub-item\">\n                        <div class=\"pub-year\">2025</div>\n                        <div class=\"pub-title\"><a href=\"https://openreview.net/forum?id=yyNP1L26c6\">Democratizing\n                                Quantitative Trading in African Markets</a></div>\n                        <div class=\"pub-venue\">AIBF 2025</div>\n                    </div>\n\n                    <div class=\"pub-item\">\n                        <div class=\"pub-year\">2024</div>\n                        <div class=\"pub-title\"><a href=\"https://conferences.kabarak.ac.ke/index.php/dsai/issue/view/15\">Enhancing HIV\n                                Testing Indicator Reporting</a></div>\n                        <div class=\"pub-venue\">DSAI Journal</div>\n                    </div>\n\n                    <div class=\"pub-item\">\n                        <div class=\"pub-year\">2023</div>\n                        <div class=\"pub-title\"><a href=\"https://openreview.net/forum?id=Hk7QOUpP82\">The Future Remains\n                                Unsupervised</a></div>\n                        <div class=\"pub-venue\">Deep Learning Indaba</div>\n                    </div>\n                </div>\n\n                <div class=\"sidebar-section\">\n                    <div class=\"diary-box\">\n                        <h3>Research Diary</h3>\n                        <p>Working notes, paper annotations, technical history from n-grams to Transformers.</p>\n                        <a href=\"https://github.com/ashioyajotham/ai_research\">Browse the repo →</a>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <footer>\n            © Ashioya Jotham Victor\n        </footer>\n    </div>\n\n\n</body></html>",
