    "html": "<html lang=\"en\"><head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Projects | Ashioya Jotham Victor</title>\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"elephant.ico\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css\">\n    <script src=\"main.js\"></script>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Georgia', serif;\n            line-height: 1.75;\n            color: #1a1a1a;\n            background: #fafafa;\n        }\n\n        .container {\n            max-width: 1100px;\n            margin: 0 auto;\n            padding: 2rem 1.5rem;\n        }\n\n        nav {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            margin-bottom: 3rem;\n        }\n\n        nav a {\n            color: #666;\n            text-decoration: none;\n            margin-right: 1.5rem;\n            font-size: 0.9rem;\n        }\n\n        nav a:hover {\n            color: #1a1a1a;\n        }\n\n        /* Hero */\n        .hero {\n            max-width: 680px;\n            margin: 0 auto 3rem;\n            padding-bottom: 2.5rem;\n            border-bottom: 1px solid #e0e0e0;\n            text-align: center;\n        }\n\n        .hero h1 {\n            font-size: 2rem;\n            font-weight: 400;\n            line-height: 1.3;\n            margin-bottom: 1rem;\n            letter-spacing: -0.02em;\n        }\n\n        .hero p {\n            font-size: 1.05rem;\n            color: #444;\n        }\n\n        /* Main layout */\n        .main-content {\n            display: grid;\n            grid-template-columns: 1fr 280px;\n            gap: 3rem;\n        }\n\n        @media (max-width: 800px) {\n            .main-content {\n                grid-template-columns: 1fr;\n            }\n\n            .sidebar {\n                order: -1;\n            }\n        }\n\n        /* Section styling */\n        h2.section-title {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 0.75rem;\n            font-weight: 600;\n            text-transform: uppercase;\n            letter-spacing: 0.1em;\n            color: #888;\n            margin-bottom: 1.5rem;\n            padding-bottom: 0.5rem;\n            border-bottom: 1px solid #e0e0e0;\n        }\n\n        /* Featured project */\n        .featured {\n            margin-bottom: 3rem;\n        }\n\n        .featured-card {\n            background: #fff;\n            border: 1px solid #e0e0e0;\n            padding: 2rem;\n        }\n\n        .featured-label {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 0.7rem;\n            text-transform: uppercase;\n            letter-spacing: 0.1em;\n            color: #888;\n            margin-bottom: 0.75rem;\n        }\n\n        .featured-title {\n            font-size: 1.5rem;\n            font-weight: 400;\n            margin-bottom: 0.75rem;\n        }\n\n        .featured-title a {\n            color: inherit;\n            text-decoration: none;\n        }\n\n        .featured-title a:hover {\n            text-decoration: underline;\n        }\n\n        .featured-desc {\n            color: #444;\n            margin-bottom: 1rem;\n        }\n\n        .featured-meta {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 0.85rem;\n            color: #888;\n        }\n\n        .featured-links {\n            margin-top: 1.25rem;\n            display: flex;\n            gap: 1rem;\n        }\n\n        .featured-links a {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 0.85rem;\n            color: #1a1a1a;\n            text-decoration: none;\n            padding: 0.4rem 0.75rem;\n            border: 1px solid #ccc;\n        }\n\n        .featured-links a:hover {\n            background: #f5f5f5;\n        }\n\n        /* Project list */\n        .project-list {\n            margin-bottom: 3rem;\n        }\n\n        .project-item {\n            padding: 1.5rem 0;\n            border-bottom: 1px solid #eee;\n        }\n\n        .project-item:first-child {\n            padding-top: 0;\n        }\n\n        .project-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: baseline;\n            gap: 1rem;\n            margin-bottom: 0.5rem;\n            flex-wrap: wrap;\n        }\n\n        .project-title {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 1.05rem;\n            font-weight: 600;\n        }\n\n        .project-title a {\n            color: inherit;\n            text-decoration: none;\n        }\n\n        .project-title a:hover {\n            color: #0066cc;\n        }\n\n        .project-status {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 0.7rem;\n            text-transform: uppercase;\n            letter-spacing: 0.05em;\n            padding: 0.2rem 0.5rem;\n            border-radius: 2px;\n        }\n\n        .status-research {\n            background: #e3f2fd;\n            color: #1565c0;\n        }\n\n        .status-tool {\n            background: #e8f5e9;\n            color: #2e7d32;\n        }\n\n        .status-active {\n            background: #fff3e0;\n            color: #e65100;\n        }\n\n        .project-desc {\n            font-size: 0.95rem;\n            color: #555;\n            margin-bottom: 0.5rem;\n        }\n\n        .project-links {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n            font-size: 0.8rem;\n        }\n\n        .project-links a {\n            color: #666;\n            text-decoration: none;\n            margin-right: 1rem;\n        }\n\n        .project-links a:hover {\n            color: #1a1a1a;\n        }\n\n        /* Sidebar */\n        .sidebar {\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n        }\n\n        .sidebar-section {\n            margin-bottom: 2.5rem;\n        }\n\n        .sidebar-section h3 {\n            font-size: 0.75rem;\n            font-weight: 600;\n            text-transform: uppercase;\n            letter-spacing: 0.1em;\n            color: #888;\n            margin-bottom: 1rem;\n        }\n\n        /* Categories */\n        .category-list {\n            list-style: none;\n        }\n\n        .category-item {\n            display: flex;\n            justify-content: space-between;\n            padding: 0.5rem 0;\n            border-bottom: 1px solid #eee;\n            font-size: 0.9rem;\n        }\n\n        .category-count {\n            color: #888;\n        }\n\n        /* Tools callout */\n        .tools-box {\n            background: #fff;\n            border: 1px solid #e0e0e0;\n            padding: 1.25rem;\n        }\n\n        .tools-box h3 {\n            font-size: 0.9rem;\n            font-weight: 600;\n            margin-bottom: 0.5rem;\n        }\n\n        .tools-box p {\n            font-size: 0.85rem;\n            color: #666;\n            margin-bottom: 0.75rem;\n        }\n\n        .tools-box code {\n            display: block;\n            background: #f5f5f5;\n            padding: 0.5rem 0.75rem;\n            font-size: 0.8rem;\n            margin-bottom: 0.5rem;\n            font-family: 'SF Mono', Consolas, monospace;\n        }\n\n        .tools-box a {\n            font-size: 0.8rem;\n            color: #1a1a1a;\n            text-decoration: none;\n        }\n\n        footer {\n            margin-top: 4rem;\n            padding-top: 1.5rem;\n            border-top: 1px solid #e0e0e0;\n            font-size: 0.85rem;\n            color: #888;\n            font-family: -apple-system, BlinkMacSystemFont, sans-serif;\n        }\n\n        /* Theme toggle */\n        .theme-toggle {\n            background: none;\n            border: none;\n            cursor: pointer;\n            font-size: 1rem;\n            color: #666;\n            padding: 0.25rem;\n            vertical-align: middle;\n        }\n\n        /* Dark mode */\n        body.dark-mode {\n            background: #1a1a2e;\n            color: #e0e0e0;\n        }\n\n        body.dark-mode .container {\n            background: #1a1a2e;\n        }\n\n        body.dark-mode nav a {\n            color: #aaa;\n        }\n\n        body.dark-mode nav a:hover {\n            color: #fff;\n        }\n\n        body.dark-mode .theme-toggle {\n            color: #aaa;\n        }\n\n        body.dark-mode .hero h1 {\n            color: #f0f0f0;\n        }\n\n        body.dark-mode .hero {\n            border-bottom-color: #444;\n        }\n\n        body.dark-mode .hero p {\n            color: #bbb;\n        }\n\n        body.dark-mode .featured-card {\n            background: #252540;\n            border-color: #444;\n        }\n\n        body.dark-mode .featured-title a {\n            color: #f0f0f0;\n        }\n\n        body.dark-mode .featured-desc {\n            color: #bbb;\n        }\n\n        body.dark-mode .featured-links a {\n            color: #f0f0f0;\n            border-color: #555;\n        }\n\n        body.dark-mode .featured-links a:hover {\n            background: #333;\n        }\n\n        body.dark-mode .section-title {\n            color: #888;\n            border-bottom-color: #444;\n        }\n\n        body.dark-mode .project-item {\n            border-bottom-color: #333;\n        }\n\n        body.dark-mode .project-title a {\n            color: #f0f0f0;\n        }\n\n        body.dark-mode .project-title a:hover {\n            color: #6db3f2;\n        }\n\n        body.dark-mode .project-desc {\n            color: #aaa;\n        }\n\n        body.dark-mode .project-links a {\n            color: #888;\n        }\n\n        body.dark-mode .project-links a:hover {\n            color: #fff;\n        }\n\n        body.dark-mode .category-item {\n            border-bottom-color: #333;\n        }\n\n        body.dark-mode .tools-box {\n            background: #252540;\n            border-color: #444;\n        }\n\n        body.dark-mode .tools-box p {\n            color: #aaa;\n        }\n\n        body.dark-mode .tools-box code {\n            background: #1a1a2e;\n            color: #6db3f2;\n        }\n\n        body.dark-mode .tools-box a {\n            color: #6db3f2;\n        }\n\n        body.dark-mode footer {\n            border-top-color: #444;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"container\">\n        <nav>\n            <a href=\"index.html\">Home</a>\n            <a href=\"research.html\">Research</a>\n            <a href=\"projects.html\">Projects</a>\n            <a href=\"essays.html\">Essays</a>\n            <a href=\"now.html\">Now</a>\n            <button class=\"theme-toggle\" onclick=\"toggleDarkMode()\">\n                <i class=\"fas fa-moon\"></i>\n            </button>\n        </nav>\n\n        <div class=\"hero\">\n            <h1>Building tools to understand and improve AI systems.</h1>\n            <p>A mix of interpretability research, open-source tools, and experiments. Some are polished; some are\n                working prototypes. All are attempts to make progress on problems I care about.</p>\n        </div>\n\n        <div class=\"featured\">\n            <div class=\"featured-card\">\n                <div class=\"featured-label\">Featured</div>\n                <h3 class=\"featured-title\"><a href=\"https://github.com/ashioyajotham/eval-awareness-research\">Evaluation\n                        Awareness Detection in LLMs</a></h3>\n                <p class=\"featured-desc\">Do language models internally represent being monitored? This project uses\n                    linear probing to detect \"evaluation awareness\" — finding 92.3% accuracy at layer 16 with partial\n                    transfer to subtle monitoring cues. The open question: does this awareness causally affect model\n                    behavior?</p>\n                <div class=\"featured-meta\">Mechanistic Interpretability · AI Safety · 2025</div>\n                <div class=\"featured-links\">\n                    <a href=\"https://github.com/ashioyajotham/eval-awareness-research\">GitHub</a>\n                    <a href=\"https://colab.research.google.com/github/ashioyajotham/eval-awareness-research/blob/main/notebooks/eval_awareness.ipynb\">Run\n                        in Colab</a>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"main-content\">\n            <div class=\"content\">\n                <div class=\"project-list\">\n                    <h2 class=\"section-title\">Interpretability &amp; Safety</h2>\n\n                    <div class=\"project-item\">\n                        <div class=\"project-header\">\n                            <span class=\"project-title\"><a href=\"https://github.com/ashioyajotham/cot-faithfulness-mech-interp\">Chain-of-Thought\n                                    Faithfulness Analysis</a></span>\n                            <span class=\"project-status status-research\">Research</span>\n                        </div>\n                        <p class=\"project-desc\">Mechanistic analysis of reasoning in GPT-2. Attribution graphs,\n                            faithfulness detection, and targeted interventions. Are CoT traces real reasoning or\n                            post-hoc rationalization?</p>\n                        <div class=\"project-links\">\n                            <a href=\"https://github.com/ashioyajotham/cot-faithfulness-mech-interp\">Code</a>\n                            <a href=\"https://github.com/ashioyajotham/cot-faithfulness-mech-interp#-key-results-preview\">Results</a>\n                        </div>\n                    </div>\n\n                    <div class=\"project-item\">\n                        <div class=\"project-header\">\n                            <span class=\"project-title\"><a href=\"https://github.com/ashioyajotham/greater-than-circuit\">Greater Than\n                                    Circuit</a></span>\n                            <span class=\"project-status status-research\">Research</span>\n                        </div>\n                        <p class=\"project-desc\">Reverse-engineering the circuit responsible for numerical comparisons in\n                            GPT-2 Small using activation patching and mechanistic interpretability techniques.</p>\n                        <div class=\"project-links\">\n                            <a href=\"https://github.com/ashioyajotham/greater-than-circuit\">Code</a>\n                        </div>\n                    </div>\n\n                    <div class=\"project-item\">\n                        <div class=\"project-header\">\n                            <span class=\"project-title\"><a href=\"https://github.com/ashioyajotham/exploring_saes\">Exploring SAEs</a></span>\n                            <span class=\"project-status status-research\">Research</span>\n                        </div>\n                        <p class=\"project-desc\">Sparse Autoencoder implementation for neural network interpretability.\n                            Features interactive visualization dashboard and W&amp;B integration.</p>\n                        <div class=\"project-links\">\n                            <a href=\"https://github.com/ashioyajotham/exploring_saes\">Code</a>\n                            <a href=\"https://wandb.ai/ashioyajotham/sae-interpretability\">W&amp;B Dashboard</a>\n                        </div>\n                    </div>\n\n                    <div class=\"project-item\">\n                        <div class=\"project-header\">\n                            <span class=\"project-title\"><a href=\"https://github.com/ashioyajotham/Value-Aligned-Confabulation-VAC-Research\">Value-Aligned\n                                    Confabulation (VAC)</a></span>\n                            <span class=\"project-status status-research\">Research</span>\n                        </div>\n                        <p class=\"project-desc\">Framework for evaluating when LLM \"hallucination\" is harmful vs.\n                            beneficial speculation. Novel metrics for the truthfulness-utility trade-off.</p>\n                        <div class=\"project-links\">\n                            <a href=\"https://github.com/ashioyajotham/Value-Aligned-Confabulation-VAC-Research\">Code</a>\n                            <a href=\"https://ashioyajotham.substack.com/p/hallucinations-in-large-language\">Article</a>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"project-list\">\n                    <h2 class=\"section-title\">Applications &amp; Tools</h2>\n\n                    <div class=\"project-item\">\n                        <div class=\"project-header\">\n                            <span class=\"project-title\"><a href=\"https://github.com/ashioyajotham/fingpt_trader\">FinGPT\n                                    Trader</a></span>\n                            <span class=\"project-status status-active\">Active</span>\n                        </div>\n                        <p class=\"project-desc\">Algorithmic trading system using confidence-weighted sentiment analysis.\n                            Fine-tuned Falcon-7B for African markets with lightweight technical analysis.</p>\n                        <div class=\"project-links\">\n                            <a href=\"https://github.com/ashioyajotham/fingpt_trader\">Code</a>\n                            <a href=\"https://openreview.net/forum?id=yyNP1L26c6\">Paper</a>\n                        </div>\n                    </div>\n\n                    <div class=\"project-item\">\n                        <div class=\"project-header\">\n                            <span class=\"project-title\"><a href=\"https://github.com/ashioyajotham/weather_forecasting_lora\">Weather Forecasting\n                                    with LoRA</a></span>\n                            <span class=\"project-status status-active\">Active</span>\n                        </div>\n                        <p class=\"project-desc\">Testing \"LoRA Without Regret\" methodology. Transforms numerical weather\n                            data → natural language forecasts via parameter-efficient fine-tuning with RLHF.</p>\n                        <div class=\"project-links\">\n                            <a href=\"https://github.com/ashioyajotham/weather_forecasting_lora\">Code</a>\n                        </div>\n                    </div>\n\n                    <div class=\"project-item\">\n                        <div class=\"project-header\">\n                            <span class=\"project-title\"><a href=\"ai-compute-simulator/\">AI Compute Growth\n                                    Simulator</a></span>\n                            <span class=\"project-status status-tool\">Tool</span>\n                        </div>\n                        <p class=\"project-desc\">Interactive visualization of exponential AI infrastructure growth.\n                            Compute capacity, investment costs, power requirements. Based on Epoch AI data.</p>\n                        <div class=\"project-links\">\n                            <a href=\"ai-compute-simulator/\">Launch</a>\n                            <a href=\"https://epoch.ai/data/ai-chip-sales\">Data Source</a>\n                        </div>\n                    </div>\n\n                    <div class=\"project-item\">\n                        <div class=\"project-header\">\n                            <span class=\"project-title\"><a href=\"elimu-research-assistant/\">Elimu Research Assistant</a></span>\n                            <span class=\"project-status status-tool\">Tool</span>\n                        </div>\n                        <p class=\"project-desc\">AI-powered tool enabling Kenyan educators to generate locally relevant,\n                            credibly sourced educational content using the ReAct framework. Addresses the \"context\n                            deficit\" in Kenyan classrooms.</p>\n                        <div class=\"project-links\">\n                            <a href=\"elimu-research-assistant/\">Landing Page</a>\n                            <a href=\"https://github.com/ashioyajotham/Elimu-Research-Assistant\">GitHub</a>\n                            <a href=\"https://pypi.org/project/elimu-research-assistant/\">PyPI</a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"sidebar\">\n                <div class=\"sidebar-section\">\n                    <h3>Categories</h3>\n                    <ul class=\"category-list\">\n                        <li class=\"category-item\">\n                            <span>Interpretability</span>\n                            <span class=\"category-count\">5</span>\n                        </li>\n                        <li class=\"category-item\">\n                            <span>AI Safety</span>\n                            <span class=\"category-count\">4</span>\n                        </li>\n                        <li class=\"category-item\">\n                            <span>Tools</span>\n                            <span class=\"category-count\">3</span>\n                        </li>\n                        <li class=\"category-item\">\n                            <span>Finance</span>\n                            <span class=\"category-count\">1</span>\n                        </li>\n                    </ul>\n                </div>\n\n                <div class=\"sidebar-section\">\n                    <div class=\"tools-box\">\n                        <h3>Install from PyPI</h3>\n                        <p><strong>Elimu Research Assistant</strong></p>\n                        <code>pip install elimu-research-assistant</code>\n                        <p><strong>Bible</strong> — Scripture CLI</p>\n                        <code>pip install biblia</code>\n                        <p><strong>Web Research Agent</strong></p>\n                        <code>pip install web-research-agent</code>\n                        <a href=\"https://pypi.org/user/ashioyajotham/\">View on PyPI →</a>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <footer>\n            © Ashioya Jotham Victor\n        </footer>\n    </div>\n\n\n</body></html>",
